# GitHub App / PAT
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret
# For GitHub Enterprise (Flipkart internal):
GITHUB_API_BASE=https://github.fkinternal.com/api/v3

# AI (litellm — OpenAI compatible)
LLM_MODEL=gpt-4o
OPENAI_API_KEY=sk-...
# Or point at an internal LLM proxy:
# OPENAI_API_BASE=https://your-internal-llm-proxy/v1

# Redis
REDIS_URL=redis://localhost:6379/0

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/pr_agent

# App settings
APP_ENV=development
LOG_LEVEL=INFO
MAX_DIFF_SIZE_KB=500
SKIP_AI_FOR_LARGE_PRS=true
LARGE_PR_FILE_THRESHOLD=50
